# Copy to .env and fill in.
#
# --- FRONTEND (Next exposes only NEXT_PUBLIC_-prefixed vars to the browser) ---
# The anon/publishable key is safe to ship — RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin for canonical URLs / sitemap / robots / OG. Unset defaults to
# https://simxmargo.github.io (the GitHub Pages org site). Point at a custom domain
# later to switch everywhere with no code edits. See docs/DEPLOY_GITHUB_PAGES.md.
NEXT_PUBLIC_SITE_URL=
# Where the public "Work with me" form POSTs. Unset = /api/collab (the Next route,
# for local dev). The static Pages build uses the Supabase Edge Function instead:
#   https://zzgypushqcpchfxrjexc.supabase.co/functions/v1/collab
NEXT_PUBLIC_COLLAB_ENDPOINT=

# Admin login email for the /admin studio. NOT a secret — it identifies the single
# admin account; the influencer only types the password. Must match the Supabase Auth
# user. It ships in the public bundle by design (single-password login).
NEXT_PUBLIC_ADMIN_EMAIL=

# --- SUPABASE CLI / scripts (server-only; used by scripts/sb.mjs + db-apply.mjs) ---
SUPABASE_PROJECT_REF=
# Account-level Personal Access Token (sbp_...). Overrides the global `supabase
# login` for THIS repo so multiple projects can be worked at once. Also paste it
# into .mcp.json. Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# DB password — only for `npm run db:push` on an IPv6-capable network.
SUPABASE_DB_PASSWORD=

# --- ADMIN write path (server-only; for /admin in a later phase) ---
# NEVER prefix these NEXT_PUBLIC_. The service-role key bypasses RLS; ADMIN_SECRET
# (the single passphrase) is the only gate in front of it, checked server-side.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SECRET=

# OPTIONAL — clean square brand logos for "Add brand from URL" (Phase 6). When set,
# scrape-meta returns a logo.dev logo (resolved by domain) instead of the page's
# og:image. Get a free publishable token at https://www.logo.dev (dashboard → API).
# Unset = the scraper falls back to og:image then favicon. Server-only; NOT public.
LOGO_DEV_TOKEN=

# OPTIONAL — "Pull videos" tool (Brand Partners → Pull videos). Fetches a creator's
# OWN recent TikTok/Instagram posts by handle so they can be auto-matched to brands.
# Uses the ScrapeCreators managed API (a direct server fetch of TikTok only gets the
# SlardarWAF JS-challenge shell). Get a free key (1000 credits, no card, never expire)
# at https://app.scrapecreators.com. Unset = the Pull-videos tool returns a clear
# "key not configured" error.
#
# This is read by the `pull-videos` Edge Function, NOT the Next server, so set it as a
# Supabase Function secret (this .env line is just a reminder):
#   npm run sb -- secrets set SCRAPECREATORS_API_KEY=sk_...
# Server-only; NEVER prefix NEXT_PUBLIC_.
SCRAPECREATORS_API_KEY=

# NOTE: social follower counts are edited by hand in admin → Social Stats, with an
# "Auto-fetch" button. ONLY TikTok + Instagram are auto-fetchable, keyless, from the
# PUBLIC profile pages (Instagram via a link-preview crawler UA — see
# lib/social/scrape.ts). Facebook exposes no public count and is MANUAL ONLY (no
# token, no scrape). The influencer always confirms + Saves (manual is the truth).

# NOTE: other secrets (Gmail OAuth client secret, Hunter.io key, Anthropic key)
# live as Supabase Edge Function secrets on the server, not here. See docs/BACKEND_DESIGN.md.
