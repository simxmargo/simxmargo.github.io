# Copy to .env and fill in.
#
# --- FRONTEND (Next exposes only NEXT_PUBLIC_-prefixed vars to the browser) ---
# The anon/publishable key is safe to ship — RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SUPABASE CLI / scripts (server-only; used by scripts/sb.mjs + db-apply.mjs) ---
SUPABASE_PROJECT_REF=
# Account-level Personal Access Token (sbp_...). Overrides the global `supabase
# login` for THIS repo so multiple projects can be worked at once. Also paste it
# into .mcp.json. Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# DB password — only for `npm run db:push` on an IPv6-capable network.
SUPABASE_DB_PASSWORD=

# --- ADMIN write path (server-only; for /admin in a later phase) ---
# NEVER prefix these NEXT_PUBLIC_. The service-role key bypasses RLS; ADMIN_SECRET
# (the single passphrase) is the only gate in front of it, checked server-side.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SECRET=

# NOTE: other secrets (Gmail OAuth client secret, Hunter.io key, Anthropic key)
# live as Supabase Edge Function secrets on the server, not here. See docs/BACKEND_DESIGN.md.
