{
  "mcpServers": {
    "supabase-brandoutreach": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=zzgypushqcpchfxrjexc"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "sbp_REDACTED__paste_your_brand-outreach_personal_access_token_here"
      }
    }
  }
}
